import { Hono } from "hono";
import { cors } from "hono/cors";

const app = new Hono()
  .use("/*", cors())
  .get("/health", (c) => c.json({ status: "ok" }))
  .get("/hello/:name", (c) => {
    const name = c.req.param("name");
    return c.json({ greeting: `Hello ${name}!` });
  });

export type AppType = typeof app;
export { app };
