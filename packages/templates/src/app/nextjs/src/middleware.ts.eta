<% if (it.app.i18n) { %>import createMiddleware from "next-intl/middleware";
import { routing } from "./i18n/routing";

export default createMiddleware(routing);

export const config = {
  // Skip static assets and api routes; route everything else through i18n.
  matcher: ["/((?!api|_next|_vercel|.*\\..*).*)"],
};
<% } %>