<% if (it.css.framework === 'tailwind4') { %>@import "tailwindcss";
<% if (it.css.ui === 'shadcn') { %>@import "tw-animate-css";
<% } %><% for (const source of it.wiring.cssSourceDirectives) { %>@source "<%= source %>";
<% } %>
@custom-variant dark (&:is(.dark *));
<% } else { %>/* Global styles */
<% } %>
