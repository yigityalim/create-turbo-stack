{
  "name": "create-turbo-stack",
  "version": "1.0.0",
  "description": "Scaffold production-ready Turborepo monorepos in seconds",
  "type": "module",
  "bin": {
    "create-turbo-stack": "dist/bin/create-turbo-stack.js"
  },
  "files": ["dist"],
  "scripts": {
    "dev": "tsx bin/create-turbo-stack.ts",
    "build": "tsup",
    "lint": "biome check",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^14.0.3",
    "eta": "^4.5.1",
    "lz-string": "^1.5.0",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@create-turbo-stack/analyzer": "workspace:*",
    "@create-turbo-stack/core": "workspace:*",
    "@create-turbo-stack/schema": "workspace:*",
    "@create-turbo-stack/templates": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "turborepo",
    "monorepo",
    "scaffold",
    "cli",
    "create",
    "turbo",
    "nextjs",
    "typescript"
