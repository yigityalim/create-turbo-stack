{
  "name": "create-turbo-stack",
  "version": "0.0.0",
  "private": true,
  "description": "Scaffold production-ready Turborepo monorepos in seconds",
  "author": "Mehmet Yigit Yalim",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yigityalim/create-turbo-stack.git"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "turbo": "^2.8.18",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
