{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "create-turbo-stack Registry",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "const": "registry:preset"
          },
          "author": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "preset": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "name",
          "title",
          "description",
          "type",
          "preset"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "name",
    "items"
  ],
  "additionalProperties": false
}